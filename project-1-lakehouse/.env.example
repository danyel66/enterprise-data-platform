# Azure
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=rg-enterprise-data-platform
AZURE_STORAGE_ACCOUNT=stadataplatformedp
AZURE_STORAGE_KEY=your-storage-key
ADLS_CONTAINER=lakehouse

# Databricks
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your-databricks-token
DATABRICKS_CLUSTER_ID=your-cluster-id

# Unity Catalog
UNITY_CATALOG_NAME=enterprise_dc_platform
UNITY_METASTORE_ID=your-metastore-id

# EIA Energy API (free at eia.gov)
EIA_API_KEY=your-eia-api-key
EIA_BASE_URL=https://api.eia.gov/v2

# Confluent Kafka (free tier)
KAFKA_BOOTSTRAP_SERVERS=your-cluster.confluent.cloud:9092
KAFKA_API_KEY=your-kafka-api-key
KAFKA_API_SECRET=your-kafka-api-secret
KAFKA_TOPIC_ENERGY=energy-sensor-readings

# MLflow
MLFLOW_TRACKING_URI=databricks
MLFLOW_EXPERIMENT_NAME=/enterprise-dc/demand-forecasting

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
